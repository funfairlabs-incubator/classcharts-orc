# ── ClassCharts ──────────────────────────────────────────────
CLASSCHARTS_PARENT1_EMAIL=parent@example.com
CLASSCHARTS_PARENT1_CODE=ACCESS_CODE_HERE
# Add second parent if needed:
# CLASSCHARTS_PARENT2_EMAIL=partner@example.com
# CLASSCHARTS_PARENT2_CODE=ACCESS_CODE_HERE

# ── GCP ──────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCS_BUCKET=your-classcharts-bucket
GCS_ALLOWED_USERS_PATH=config/allowed-users.json

# ── Google OAuth (NextAuth) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=https://your-app.appspot.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Admin ─────────────────────────────────────────────────────
# Your GitHub-linked Gmail — has sudo access
ADMIN_EMAIL=you@gmail.com

# ── Pushover ──────────────────────────────────────────────────
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
# Optional second recipient (partner):
# PUSHOVER_USER_KEY_2=

# ── Gmail API (for email watching) ───────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Poller ────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=5

# ── Anthropic (Claude summarisation) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Calendar (poller) ──────────────────────────────────
GCAL_REFRESH_TOKEN=
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET already set above

# ── ClassCharts password (updated from CODE) ──────────────────
# Note: env var renamed from CLASSCHARTS_PARENT1_CODE to CLASSCHARTS_PARENT1_PASSWORD
CLASSCHARTS_PARENT1_PASSWORD=your_classcharts_password
